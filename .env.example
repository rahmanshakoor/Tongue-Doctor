# Tongue-Doctor environment template.
# Copy to .env (gitignored) and fill values for local dev.
# Production values come from Secret Manager — do NOT commit real secrets here.

# --- Runtime environment ---
# One of: dev, prod. Selects which config/<env>.yaml overlays config/default.yaml.
TONGUE_DOCTOR_ENV=dev

# --- Logging ---
# DEBUG / INFO / WARNING / ERROR. Overrides config/<env>.yaml.
LOG_LEVEL=DEBUG

# --- GCP ---
# Project ID is intentionally left blank until open item 21 is resolved.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=me-central1
# Optional fallback region for Anthropic / Cohere model availability.
GOOGLE_CLOUD_FALLBACK_REGION=europe-west4

# --- Secret Manager ---
# When true, settings.py loads secrets from Secret Manager at boot.
# When false, secrets must be set as env vars below for local dev.
USE_SECRET_MANAGER=false

# --- Anthropic direct fallback (used when Vertex Model Garden returns UNAVAILABLE) ---
ANTHROPIC_API_KEY=

# --- Premium clinical reference subscriptions (set when item 22 is resolved) ---
UPTODATE_API_KEY=
LEXICOMP_API_KEY=
MICROMEDEX_API_KEY=
DRUGBANK_API_KEY=
BMJ_API_KEY=
DYNAMED_API_KEY=
VISUALDX_API_KEY=

# --- Retrieval providers ---
COHERE_API_KEY=

# --- Ontology services ---
UMLS_API_KEY=

# --- Tracing ---
# When true, tracing.py exports spans to Cloud Trace.
TRACING_ENABLED=false

# --- Firestore emulator (dev only) ---
# When set, the case manager talks to a local emulator instead of GCP.
FIRESTORE_EMULATOR_HOST=
